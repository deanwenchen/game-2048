---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const SITE_URL = 'https://2048.lazytoolshub.top';
const SITE_NAME = '2048 Cyberpunk';
const DEFAULT_KEYWORDS = '2048 game, 2048 online, 2048 unblocked, play 2048 free, cyberpunk 2048, puzzle game, browser game';

const {
  title,
  description = '2048 Cyberpunk',
  canonicalUrl,
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = canonicalUrl || new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE_URL).href;
const SUPPORTED_LANGS = ['en','zh','es','fr','de','ja','pt','ar','ko','ru','tr','th','hi','it'];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0a0a1a" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
  <meta name="googlebot" content="index, follow" />
  <meta name="format-detection" content="telephone=no" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={DEFAULT_KEYWORDS} />
  <meta name="author" content={SITE_NAME} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

  <!-- hreflang alternates -->
  <link rel="alternate" hreflang="en" href={`${SITE_URL}/`} />
  {SUPPORTED_LANGS.filter(l => l !== 'en').map(l => (
    <link rel="alternate" hreflang={l} href={`${SITE_URL}/?lang=${l}`} />
  ))}
  <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={SITE_NAME} />
  <meta property="og:locale" content="en_US" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="dns-prefetch" href="https://fonts.googleapis.com" />

  <!-- Structured Data: VideoGame -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": SITE_NAME,
    "description": description,
    "url": canonical,
    "applicationCategory": "Game",
    "operatingSystem": "Any (Web Browser)",
    "browserRequirements": "Requires JavaScript",
    "inLanguage": SUPPORTED_LANGS,
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "ratingCount": "127",
      "bestRating": "5",
      "worstRating": "1"
    }
  })} />

  <!-- Structured Data: Organization -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Lazy Tools Hub",
    "url": "https://lazytoolshub.top"
  })} />

  <!-- Structured Data: BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE_URL }
    ]
  })} />

  <!-- Sync <html lang>/<html dir> with selected i18n locale -->
  <script is:inline>
    (function () {
      var supported = ['en','zh','es','fr','de','ja','pt','ar','ko','ru','tr','th','hi','it'];
      var rtl = ['ar'];
      function pick() {
        try { var q = new URL(location.href).searchParams.get('lang'); if (q && supported.indexOf(q) >= 0) return q; } catch (e) {}
        try { var s = localStorage.getItem('siteLang'); if (s && supported.indexOf(s) >= 0) return s; } catch (e) {}
        var n = (navigator.language || 'en').toLowerCase().split('-')[0];
        return supported.indexOf(n) >= 0 ? n : 'en';
      }
      var lang = pick();
      document.documentElement.lang = lang;
      document.documentElement.dir = rtl.indexOf(lang) >= 0 ? 'rtl' : 'ltr';
    })();
  </script>
</head>
<body>
  <slot />
    <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid #333">
      <h2 style="color:#666;font-size:0.7rem;font-weight:600;text-transform:uppercase;letter-spacing:0.15em;margin-bottom:1rem;text-align:center">More Free Online Tools</h2>
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:0.5rem 1rem;font-size:0.75rem">
              <a href="https://cat-age-calc.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Cat Age Calculator</a>
              <a href="https://freelance-rate-calc.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Freelance Rate Calculator</a>
              <a href="https://jargon.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Jargon Translator</a>
              <a href="https://keto-carb.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Keto Carb Calculator</a>
              <a href="https://pass-gen.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Password Generator</a>
              <a href="https://pet-toxicity.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Pet Toxicity Calculator</a>
              <a href="https://pet-water.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Pet Water Intake Calculator</a>
              <a href="https://running-pace.lazytoolshub.top" style="color:#666;text-decoration:none;transition:color 0.2s" target="_blank" rel="noopener" onmouseover="this.style.color='#aaa'" onmouseout="this.style.color='#666'">Running Pace Calculator</a>
