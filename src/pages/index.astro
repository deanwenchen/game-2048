---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const TITLE = 'Play 2048 Online Free - Cyberpunk Edition | 2048 Game Unblocked';
const DESC = 'Play 2048 game online for free. Cyberpunk neon theme, smooth animations, keyboard & swipe controls. No download, no registration. The ultimate unblocked 2048 puzzle game.';
---

<Layout title={TITLE} description={DESC}>
    <header class="hero">
      <h1>2048</h1>
      <p class="subtitle" data-i18n="subtitle">Cyberpunk Edition - Slide, Merge, Conquer</p>
    </header>

    <main class="game-layout">
      <aside class="ad-slot ad-slot-side" aria-label="Advertisement"><span>Ad Space</span></aside>

      <div class="game-column">
        <div class="score-bar">
          <div class="score-box">
            <span class="score-label" data-i18n="scoreLabel">Score</span>
            <span class="score-value" id="score">0</span>
          </div>
          <div class="score-box">
            <span class="score-label" data-i18n="bestLabel">Best</span>
            <span class="score-value" id="best-score">0</span>
          </div>
          <button class="btn-restart" id="btn-restart" aria-label="Restart game" data-i18n="newGame">New Game</button>
        </div>

        <div class="game-container">
          <div class="grid-board" id="grid-board">
            <div class="grid-bg" id="grid-bg"></div>
            <div class="tile-layer" id="tile-layer"></div>
          </div>

          <div class="game-overlay" id="game-overlay">
            <h2 id="overlay-title" data-i18n="gameOver">Game Over</h2>
            <p id="overlay-text" data-i18n="finalScore">Final Score: 0</p>
            <div class="overlay-buttons" id="overlay-buttons">
              <button class="btn-overlay primary" id="btn-restart-overlay" data-i18n="newGame">New Game</button>
              <button class="btn-overlay secondary" id="btn-continue" style="display:none;" data-i18n="keepPlaying">Keep Playing</button>
            </div>
          </div>
        </div>

        <div class="ad-slot ad-slot-bottom" aria-label="Advertisement"><span>Ad Space</span></div>
      </div>

      <aside class="ad-slot ad-slot-side" aria-label="Advertisement"><span>Ad Space</span></aside>
    </main>

    <section class="content-section">
      <h2 data-i18n="howToTitle">How to Play 2048 Online</h2>
      <p data-i18n="howToDesc">2048 is an addictive sliding tile puzzle game. Your goal is to combine numbered tiles to reach the legendary 2048 tile.</p>
      <div class="controls-grid">
        <div class="control-item"><kbd>&uarr;</kbd> <kbd>&darr;</kbd> <kbd>&larr;</kbd> <kbd>&rarr;</kbd><p data-i18n="ctrlArrow">Arrow Keys to slide</p></div>
        <div class="control-item"><kbd>W</kbd> <kbd>A</kbd> <kbd>S</kbd> <kbd>D</kbd><p data-i18n="ctrlWasd">WASD alternative</p></div>
        <div class="control-item"><kbd data-i18n="kbdSwipe">Swipe</kbd><p data-i18n="ctrlSwipe">Touch screen swipe</p></div>
      </div>
    </section>

    <section class="content-section">
      <h2 data-i18n="rulesTitle">Game Rules &amp; Scoring</h2>
      <p data-i18n="rules1">Every time you merge two tiles, the value of the new tile is added to your score. A 2+2 merge earns 4 points, a 4+4 merge earns 8 points. The game ends when no more moves are possible.</p>
      <p data-i18n="rules2">After each move, a new tile (either 2 or 4) appears randomly on an empty cell. Plan your moves carefully to avoid filling up the board before reaching 2048!</p>
    </section>

    <section class="content-section">
      <h2 data-i18n="tipsTitle">Pro Tips &amp; Strategies</h2>
      <ul class="tips-list">
        <li data-i18n="tip1">Keep your highest-value tile in a corner. It acts as an anchor for building larger tiles.</li>
        <li data-i18n="tip2">Build a chain of descending values along one edge (e.g., 1024 → 512 → 256 → 128).</li>
        <li data-i18n="tip3">Avoid pressing the "down" arrow randomly. It breaks your corner strategy.</li>
        <li data-i18n="tip4">Plan at least 2-3 moves ahead.</li>
        <li data-i18n="tip5">When the board gets crowded, focus on freeing up space by merging low-value tiles first.</li>
        <li data-i18n="tip6">After reaching 2048, you can continue playing to chase even higher tiles like 4096 and 8192!</li>
      </ul>
    </section>

    <section class="content-section">
      <h2 data-i18n="faqTitle">Frequently Asked Questions</h2>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <h3 itemprop="name" data-i18n="fq1">Is 2048 free to play?</h3>
        <p itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer"><span itemprop="text" data-i18n="fa1">Yes, this 2048 game is completely free. No registration, no downloads.</span></p>
      </div>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <h3 itemprop="name" data-i18n="fq2">Can I play 2048 on mobile?</h3>
        <p itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer"><span itemprop="text" data-i18n="fa2">Absolutely! This 2048 game is fully responsive and supports touch swipe controls on smartphones and tablets.</span></p>
      </div>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <h3 itemprop="name" data-i18n="fq3">Does my score get saved?</h3>
        <p itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer"><span itemprop="text" data-i18n="fa3">Yes! Your best score is saved automatically in your browser's local storage.</span></p>
      </div>
      <div class="faq-item" itemscope itemtype="https://schema.org/Question">
        <h3 itemprop="name" data-i18n="fq4">What happens after I reach 2048?</h3>
        <p itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer"><span itemprop="text" data-i18n="fa4">You can choose to keep playing! After reaching 2048, click "Keep Playing" to continue.</span></p>
      </div>
    </section>

    <section class="content-section">
      <h2 data-i18n="aboutTitle">About This 2048 Game</h2>
      <p data-i18n="about1">This is the ultimate unblocked 2048 game experience, featuring a stunning cyberpunk neon aesthetic.</p>
      <p data-i18n="about2">Our 2048 game delivers smooth animations, responsive controls, and an addictive gameplay loop.</p>
      <p data-i18n="about3">Challenge yourself to beat your high score. Can you reach beyond 2048?</p>
    </section>

    <footer class="site-footer">
      <p>&copy; 2024 <a href="https://2048.lazytoolshub.top">2048.lazytoolshub.top</a> - <span data-i18n="footerNote">Free Online 2048 Game. All rights reserved.</span></p>
    </footer>

    <script is:inline>
      (function() {
        var gridBg = document.getElementById('grid-bg');
        if (!gridBg) return;
        var cs = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--cell-size'));
        var cg = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--cell-gap'));
        var gp = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--grid-pad'));
        for (var r = 0; r < 4; r++) {
          for (var c = 0; c < 4; c++) {
            var span = document.createElement('span');
            span.style.left = (gp + c * (cs + cg)) + 'px';
            span.style.top = (gp + r * (cs + cg)) + 'px';
            gridBg.appendChild(span);
          }
        }
        var restartOverlay = document.getElementById('btn-restart-overlay');
        if (restartOverlay) {
          restartOverlay.addEventListener('click', function() {
            localStorage.removeItem('2048_state');
            location.reload();
          });
        }
      })();
    </script>

    <script>
      import '../scripts/game.js';
    </script>

